{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Charly Alexa POS",
  "version": "0.1.1",
  "identifier": "mx.charlyalexa.pos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "label": "main",
      "title": "Charly Alexa POS",
      "width": 1280,
      "height": 800,
      "minWidth": 900,
      "minHeight": 650,
      "resizable": true
    }],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Charly Alexa",
    "shortDescription": "Punto de venta offline para boutique infantil"
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:charly-alexa-pos.db"]
    }
  }
}
